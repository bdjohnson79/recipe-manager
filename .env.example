SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — leave unset to use SQLite, or set to a PostgreSQL URL for Postgres
# DATABASE_URL=postgres://user:password@localhost:5432/recipe_manager

# Google OAuth (get from console.cloud.google.com → APIs & Services → Credentials)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
